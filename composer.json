{
    "name": "maksekeskus/makecommerce-php-sdk",
    "description": "MakeCommerce payment SDK",
    "keywords": [
        "php-sdk",
        "rest",
        "psr7"
    ],
    "version": "1.0.1",
    "license": "MIT",
    "authors": [
        {
            "name": "MakeCommerce",
            "email": "modules@makecommerce.net",
            "homepage": "https://makecommerce.net/"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.0",
        "justinrainbow/json-schema": "^6.6"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "process-timeout": 0,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "MakeCommerce\\": "src/"
        }
    }
}
